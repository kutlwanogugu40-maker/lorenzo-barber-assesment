body { font-family: sans-serif; margin: 0; padding: 0; }

nav { display: flex; justify-content: space-between; padding: 20px; align-items: center; border-bottom: 1px solid #ddd; }

.main-layout { 
    display: grid; 
    grid-template-columns: 2fr 1fr; 
    gap: 20px; 
    padding: 20px; 
}

.hero-content { background: #f4f4f4; padding: 40px; }

.sidebar { border-left: 1px solid #ddd; padding-left: 20px; }

.gallery-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 5px; 
}

.img-placeholder { width: 100%; height: 80px; background: #ccc; }

.map-placeholder { height: 150px; background: #eee; margin-bottom: 10px; }

.book-btn { background: red; color: white; border: none; padding: 10px 20px; cursor: pointer; }

.cta-buttons button { padding: 10px 20px; margin-right: 10px; }
/* Main Layout Container */
.page-wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr; 
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}


.sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
}


.gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); 
    gap: 5px;
}
.service-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    margin-top: 20px;
}

.service-box {
    background: #fff;
    border: 1px solid #ddd;
    padding: 15px;
    text-align: center;
    flex: 1;
    border-radius: 4px;
}

.service-box span {
    display: block;
    font-size: 0.8rem;
    font-weight: bold;
    margin-bottom: 5px;
}
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 5%;
    border-bottom: 2px solid #f4f4f4;
}

.nav-links a {
    margin: 0 15px;
    text-decoration: none;
    color: #333;
    font-weight: 500;
}

.book-now-btn {
    background: #e63946; 
    color: white;
    padding: 8px 20px;
    border: none;
    cursor: pointer;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', sans-serif;
    background-color: #f4f4f4;
    color: hsl(0, 53%, 43%);
    line-height: 1.6;
}


img {
    max-width: 100%; 
    height: auto;    
    display: block;
}


.container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
    background: #ffffff; 
    padding: 20px;
    box-shadow: 0 0 10px #3c3eb3e0;
}


.page-layout {
    display: grid;
    grid-template-columns: 2fr 1fr; 
    gap: 20px;
}


@media (max-width: 768px) {
    .page-layout {
        grid-template-columns: 1fr; 
    }
}
